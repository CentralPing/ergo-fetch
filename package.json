{
  "name": "@centralping/ergo-fetch",
  "version": "0.2.0-beta.1",
  "description": "RFC-compliant HTTP client for ergo-router APIs — conditional requests, rate limiting, pagination, and more",
  "main": "index.js",
  "type": "module",
  "types": "types/index.d.ts",
  "exports": {
    ".": {
      "types": "./types/index.d.ts",
      "default": "./index.js"
    },
    "./lib/*": {
      "types": "./types/lib/*.d.ts",
      "default": "./lib/*.js"
    },
    "./stores/*": {
      "types": "./types/stores/*.d.ts",
      "default": "./stores/*.js"
    }
  },
  "files": [
    "index.js",
    "lib/",
    "stores/",
    "types/",
    "!**/*.spec.*.js",
    "LICENSE",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "lint": "eslint .",
    "format": "prettier --write \"**/*.js\"",
    "format:check": "prettier --check \"**/*.js\"",
    "pretest": "npm run lint && npm run format:check",
    "test": "c8 node --test \"**/*.spec.unit.js\" \"**/*.spec.func.js\"",
    "test:watch": "node --test --watch \"**/*.spec.unit.js\" \"**/*.spec.func.js\"",
    "preversion": "npm test",
    "types": "tsc",
    "check-types": "npm run types && tsc --project tsconfig.check-types.json",
    "check-bundle-size": "node scripts/check-bundle-size.js",
    "prepublishOnly": "npm test && npm run check-types",
    "prepare": "simple-git-hooks"
  },
  "simple-git-hooks": {
    "pre-commit": "npx lint-staged"
  },
  "lint-staged": {
    "*.js": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "engines": {
    "node": ">=22"
  },
  "keywords": [
    "ergo",
    "fetch",
    "http-client",
    "rest",
    "api-client",
    "rfc-9457",
    "conditional-requests",
    "etag",
    "rate-limiting",
    "pagination",
    "idempotency",
    "csrf",
    "sse",
    "offline-first"
  ],
  "author": "Jason Cust <jason@centralping.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/CentralPing/ergo-fetch.git"
  },
  "bugs": {
    "url": "https://github.com/CentralPing/ergo-fetch/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "homepage": "https://centralping.github.io/packages/ergo-fetch/",
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/jasoncust"
  },
  "peerDependencies": {
    "@types/node": ">= 22"
  },
  "peerDependenciesMeta": {
    "@types/node": {
      "optional": true
    }
  },
  "dependencies": {
    "@centralping/ergo-wire": "^0.1.0-beta.2"
  },
  "devDependencies": {
    "@centralping/ergo": "^0.8.0",
    "@centralping/ergo-router": "^0.6.0",
    "@centralping/json-api-query": "^1.0.1",
    "@eslint/js": "^10.0.1",
    "@types/node": "^26.0.1",
    "c8": "^11.0.0",
    "esbuild": "^0.28.1",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.4.0",
    "lint-staged": "^17.0.3",
    "prettier": "^3.8.1",
    "simple-git-hooks": "^2.12.1",
    "typescript": "^6.0.3",
    "undici": "^8.2.0"
  },
  "c8": {
    "include": [
      "lib/**/*.js",
      "stores/**/*.js",
      "index.js"
    ],
    "exclude": [
      "**/*.spec.*.js",
      "**/node_modules/**",
      "**/coverage/**"
    ],
    "branches": 80,
    "functions": 100,
    "lines": 80,
    "statements": 80,
    "reporter": [
      "text",
      "lcov"
    ],
    "all": true
  }
}
